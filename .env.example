# ===========================================
# Environment Configuration Template
# Copy this file to .env and fill in values
# ===========================================

# ---- Supabase Configuration ----
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key is required for admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Application Configuration ----
NODE_ENV=development
PORT=5001
APP_URL=http://localhost:5001

# Node.js networking configuration (fixes DNS/timeout issues)
NODE_OPTIONS="--dns-result-order=ipv4first"

# ---- LLM / AI Configuration ----
# Get API key from: https://openrouter.ai/keys
# Used for: AI summaries (Llama 3.1 70B) + embeddings (text-embedding-3-small)
OPENROUTER_API_KEY=your-openrouter-api-key
LLM_MODEL=anthropic/claude-haiku-4-5-20250414

# ---- Email Service (Gmail SMTP) ----
# For Gmail: Enable 2FA and create an App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# ---- Zoom Integration (Optional) ----
# Get these from: Zoom App Marketplace > Server-to-Server OAuth App
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ---- Google Calendar/Meet Integration (Optional) ----
# Get these from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ---- Frontend Configuration ----
# Variables prefixed with VITE_ are exposed to the frontend
VITE_APP_TITLE=Recruitment Platform
VITE_APP_DESCRIPTION=AI-Powered Recruitment Platform
VITE_APP_LOGO=

# These should match the backend Supabase config
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Analytics (Optional) ----
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_SITE_ID=
